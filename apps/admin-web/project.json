{
  "name": "admin-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/admin-web/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm dev", "cwd": "apps/admin-web" }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm dev", "cwd": "apps/admin-web" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm build", "cwd": "apps/admin-web" },
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm start", "cwd": "apps/admin-web" }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm preview", "cwd": "apps/admin-web" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm typecheck", "cwd": "apps/admin-web" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm lint", "cwd": "apps/admin-web" }
    }
  },
  "tags": ["scope:admin-web", "type:app"],
  "implicitDependencies": ["ui", "core", "api"]
}
