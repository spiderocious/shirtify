NODE_ENV=development
PORT=9091
LOG_LEVEL=info

APP_BASE_URL=http://localhost:9091
WEB_BASE_URL=http://localhost:5173

JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/shirtify

# Storage — external R2 file-service (presigned-URL proxy)
FILE_SERVICE_URL=https://go-file-service-production.up.railway.app

# Web push (optional in dev). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@shirtify.app

# Seed seller (used by `pnpm seed`)
SEED_SELLER_EMAIL=her@shirtify.app
SEED_SELLER_PASSWORD=changeme123
SEED_SELLER_BUSINESS=Shirtify
