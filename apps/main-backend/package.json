{
  "name": "@shirtify/main-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "lint": "eslint --config ../../eslint.config.mjs 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "seed": "tsx --env-file=.env src/scripts/seed.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "@shirtify/core": "workspace:*",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "ky": "^1.7.4",
    "mongoose": "^8.9.5",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.14.1",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "mongodb-memory-server": "^10.1.3",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
